# Agent Comptable IA - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# --- Securite ---
SECRET_KEY=changeme-use-a-long-random-string
APP_USERNAME=admin
APP_PASSWORD=changeme
# APP_PASSWORD_HASH=  # Optionnel : hash SHA-256 du mot de passe (prioritaire sur APP_PASSWORD)

# Permet le login admin/APP_PASSWORD (legacy mono-user) en plus du signup multi-tenant.
# Pratique en dev pour ne pas se locker dehors. À mettre à false en prod.
ALLOW_LEGACY_ADMIN=true

# --- Base de données (PostgreSQL) ---
DB_PASSWORD=enop_dev
DATABASE_URL=postgresql://enop:enop_dev@db:5432/enop

# --- LLM principal ---
# Valeurs : 'gemini' (recommandé, primaire) ou 'claude'
PRIMARY_LLM=gemini

# --- Providers IA (extraction comptable) ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=  # Optionnel, fallback

# --- OCR ---
# Google Document AI (primaire)
GOOGLE_DOCAI_PROJECT_ID=ton-project-id
GOOGLE_DOCAI_PROCESSOR_ID=ton-processor-id
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service_account.json
# GOOGLE_API_KEY=  # Alternatif au service account JSON

# Mistral OCR (fallback si Google DocAI indisponible)
MISTRAL_API_KEY=

# --- Options ---
CACHE_ENABLED=true
FILE_RETENTION_MINUTES=10
MAX_PAGES_PER_BATCH=50
WEBHOOK_TOKEN=  # Laisser vide pour désactiver le webhook

# --- Email (optionnel) ---
EMAIL_ADDRESS=
EMAIL_PASSWORD=
